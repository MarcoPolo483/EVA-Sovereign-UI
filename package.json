{
  "name": "@eva-suite/sovereign-ui",
  "version": "1.0.0",
  "description": "Government of Canada Design System - Enterprise UI Library with multi-framework support (React, Svelte, Vue, Angular)",
  "keywords": [
    "design-system",
    "canada",
    "gc-design-system",
    "accessibility",
    "wcag",
    "bilingual",
    "i18n",
    "react",
    "svelte",
    "vue",
    "angular"
  ],
  "license": "MIT",
  "author": "EVA Suite Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcoPolo483/eva-suite.git",
    "directory": "EVA-Sovereign-UI"
  },
  "workspaces": [
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/blocks": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@storybook/test": "^8.0.0",
    "@types/node": "^20.0.0",
    "storybook": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
