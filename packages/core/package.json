{
  "name": "@eva-suite/sovereign-core",
  "version": "1.0.0",
  "description": "Core design tokens, styles, and utilities for EVA Sovereign UI - Government of Canada Design System",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/*": "./dist/styles/*",
    "./tokens": {
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.js",
      "types": "./dist/tokens.d.ts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.mjs",
      "require": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./assets": {
      "import": "./dist/assets.mjs",
      "require": "./dist/assets.js",
      "types": "./dist/assets.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('src/styles', 'dist/styles', {recursive: true})\"",
    "dev": "tsup --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "design-tokens",
    "gc-design-system",
    "canada",
    "accessibility",
    "wcag"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
